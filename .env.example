# Host port for the containerized dashboard.
QUOTA_DECK_PORT=4173

# Keep false for real host-collector data; set true for the animated sample.
DEMO_MODE=false

# Generate a long random value and use the same value for the Windows host collector.
DASHBOARD_SECRET=

# Leave these blank to generate/persist a viewer secret and rotate the six-digit code at startup.
QUOTA_DECK_VIEW_SECRET=
QUOTA_DECK_PAIRING_CODE=
